# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# API
API_ADDR=:8080
API_ALLOWED_ORIGINS=http://localhost:3000
API_BODY_LIMIT_BYTES=1048576
API_COOKIE_SECURE=false
DATABASE_URL=postgres://portfolio:portfolio@127.0.0.1:55432/portfolio?sslmode=disable
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-long-random-password
SESSION_SECRET=change-me
TURNSTILE_SECRET_KEY=change-me
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Local PostgreSQL container
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio
POSTGRES_PORT=55432

# MCP
MCP_ADDR=:8090
MCP_BEARER_TOKEN=change-me
MCP_ADMIN_BEARER_TOKEN=change-me-admin
MCP_ALLOWED_ORIGINS=http://localhost:3000

# Backups
BACKUP_BUCKET=portfolio-blog-backups
