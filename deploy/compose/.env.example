# Public address. Use a real domain in production, for example bpajor.dev.
# Use :80 for local VM smoke tests without automatic TLS.
SITE_ADDRESS=:80
HTTP_PORT=80
HTTPS_PORT=443

NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_API_BASE_URL=/api

API_ALLOWED_ORIGINS=https://example.com
API_COOKIE_SECURE=true

POSTGRES_USER=portfolio
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=portfolio

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-long-admin-password
SESSION_SECRET=replace-with-32-byte-random-secret
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

MCP_BEARER_TOKEN=replace-with-read-token
MCP_ADMIN_BEARER_TOKEN=replace-with-admin-token
MCP_ALLOWED_ORIGINS=https://example.com

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
