project_id         = "your-gcp-project-id"
region             = "us-central1"
zone               = "us-central1-a"
name_prefix        = "portfolio"
domain             = "bpajor.dev"
backup_bucket_name = "bpajor-portfolio-backups-unique-suffix"

# Enable after the GitHub Actions Workload Identity Pool and Provider exist.
enable_github_iap_deploy = false
# github_actions_repository = "bpajor/portfolio"
# github_actions_workload_identity_pool_id = "github-actions"
# github_actions_workload_identity_provider_id = "github"

# IAP TCP forwarding uses this Google-owned source range for SSH.
# iap_ssh_source_ranges = ["35.235.240.0/20"]

# Keep empty if you use IAP or temporary browser SSH.
# For direct SSH, set your current public IP, for example ["203.0.113.10/32"].
ssh_source_ranges = []

# The module default is the current Cloudflare IPv4 range list from:
# https://www.cloudflare.com/ips-v4
# Temporarily use ["0.0.0.0/0"] only for first Caddy certificate issuance
# or direct origin debugging, then remove the override or set Cloudflare ranges.
# web_source_ranges = ["0.0.0.0/0"]

# Optional. Enable after you know your billing account ID.
enable_billing_budget = false
billing_account_id    = ""
budget_currency_code  = "PLN"
budget_amount_units   = "50"
